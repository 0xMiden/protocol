{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*git *commit*)",
            "command": ".claude/hooks/pre-commit-lint.sh"
          },
          {
            "type": "command",
            "if": "Bash(*git push*)",
            "command": ".claude/hooks/pre-push-test.sh"
          },
          {
            "type": "command",
            "if": "Bash(*git push*)",
            "command": ".claude/hooks/pre-push-review.sh"
          }
        ]
      }
    ]
  }
}
