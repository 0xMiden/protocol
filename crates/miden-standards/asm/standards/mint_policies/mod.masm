#! Mint policy that accepts every mint request.
#!
#! Inputs:  [amount, tag, note_type, RECIPIENT]
#! Outputs: [amount, tag, note_type, RECIPIENT]
#! Invocation: dynexec
pub proc allow_all
    push.0 drop
end
