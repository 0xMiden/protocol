# The MASM code of the AggLayer Faucet Account Component.
#
# This is a thin wrapper that re-exports faucet-related procedures from the
# agglayer library. The faucet exposes:
# - `distribute` from the network fungible faucet (for MINT note consumption, with owner verification)
# - `asset_to_origin_asset` for bridge-out FPI
# - `burn` for bridge-out

pub use ::miden::agglayer::faucet::distribute
pub use ::miden::agglayer::faucet::asset_to_origin_asset
pub use ::miden::agglayer::faucet::burn
